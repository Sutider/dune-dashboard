# Dune Awakening Dashboard - Settings
# ==========================================
# All configuration in one file.
# Copy this to settings.yaml and edit for your server.
# Run 'python setup.py' for guided setup.
# ==========================================

# Server connection
server:
  host: "YOUR_SERVER_IP"       # VM IP address
  user: "dune"                 # SSH username
  ssh_key: null                # Path to SSH key (null = auto-detect)

# Dashboard
dashboard:
  host: "127.0.0.1"            # Bind address (use 0.0.0.0 for remote access)
  port: 5050                   # Port number
  debug: false                 # Set true for development only
  secret_key: "change-me-to-random-string"  # For session security
  ssl_cert: null               # Path to SSL cert (null = HTTP only)
  ssl_key: null                # Path to SSL key (null = HTTP only)
  ssl_domain: null             # Domain for Let's Encrypt (e.g. dashboard.example.com)
  ssl_email: null              # Email for Let's Encrypt notifications
                               # For Let's Encrypt or custom CA:
                               #   ssl_cert: /etc/letsencrypt/live/yourdomain/fullchain.pem
                               #   ssl_key: /etc/letsencrypt/live/yourdomain/privkey.pem

# Database (accessed via SSH tunnel)
database:
  host: "127.0.0.1"            # Local tunnel endpoint
  port: 15433                  # Local tunnel port
  user: "postgres"
  password: "postgres"
  name: "dune"
  schema: "dune"
  min_connections: 2
  max_connections: 10

# Kubernetes
kubernetes:
  namespace: ""                # Leave empty to auto-detect on first run
  battlegroup_script: "/home/dune/.dune/bin/battlegroup"

# Cache (seconds)
cache:
  chat_pod_ttl: 60
  chat_messages_ttl: 10
  static_data_ttl: 300

# Authentication
auth:
  enabled: true                # Set false to disable login (localhost only)
  username: "admin"
  password: "changeme"         # Change this!

# Logging
logging:
  level: "INFO"                # DEBUG, INFO, WARNING, ERROR
  file: "logs/dashboard.log"
  max_bytes: 10485760          # 10MB
  backup_count: 5

# SSL certificate auto-renewal
ssl:
  check_interval_hours: 24     # How often to check cert expiry
  renewal_days_before_expiry: 30  # Regenerate if expiring within this many days
